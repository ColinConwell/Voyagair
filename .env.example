# Voyagair Configuration
# Copy this file to .env and fill in your API keys.

# Amadeus API (https://developers.amadeus.com) - Free tier: 2,000 searches/month
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENVIRONMENT=test

# Kiwi Tequila API (https://tequila.kiwi.com) - Free search
KIWI_API_KEY=

# SerpAPI for Google Flights (https://serpapi.com) - Free: 250/month
SERPAPI_KEY=

# Rome2Rio API (https://www.rome2rio.com/documentation/search) - Free: 100k/month
ROME2RIO_API_KEY=

# LLM Provider for AI agent
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Or use ANTHROPIC_API_KEY / OPENAI_API_KEY / GEMINI_API_KEY directly

# Cache settings
VOYAGAIR_CACHE_DIR=.voyagair_cache
